    },
    {
      "name": "Notifications - Testing",
      "item": [
        {
          "name": "1. Check if User Has FCM Token",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/notifications/check-fcm-token?email=citizen@example.com",
              "host": ["{{base_url}}"],
              "path": ["api", "notifications", "check-fcm-token"],
              "query": [
                {
                  "key": "email",
                  "value": "citizen@example.com"
                }
              ]
            }
          }
        },
        {
          "name": "2. Send Test Notification by Email",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"citizen@example.com\",\n  \"title\": \"Test Notification\",\n  \"body\": \"If you see this, Firebase is working!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/notifications/test",
              "host": ["{{base_url}}"],
              "path": ["api", "notifications", "test"]
            }
          }
        },
        {
          "name": "3. Send Test Notification by User ID",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"507f1f77bcf86cd799439011\",\n  \"title\": \"Test Notification\",\n  \"body\": \"Testing with User ID\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/notifications/test-by-user-id",
              "host": ["{{base_url}}"],
              "path": ["api", "notifications", "test-by-user-id"]
            }
          }
        },
        {
          "name": "4. Send Custom Notification",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"citizen@example.com\",\n  \"title\": \"Fund Request Approved\",\n  \"body\": \"Your fund request of 5000 has been approved\",\n  \"data\": {\n    \"requestId\": \"req-123\",\n    \"amount\": \"5000\",\n    \"status\": \"approved\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/notifications/send",
              "host": ["{{base_url}}"],
              "path": ["api", "notifications", "send"]
            }
          }
        },
        {
          "name": "5. Update FCM Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"citizen@example.com\",\n  \"fcmToken\": \"new-fcm-token-here:APA91bHg-new-token\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/notifications/update-fcm-token",
              "host": ["{{base_url}}"],
              "path": ["api", "notifications", "update-fcm-token"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    }
  ]
}
