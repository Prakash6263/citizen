{
  "info": {
    "_postman_id": "fcm-notifications",
    "name": "Firebase Cloud Messaging API",
    "description": "Test Firebase notification endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Citizen Login with FCM Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"citizen@example.com\",\n  \"password\": \"password123\",\n  \"fcmToken\": \"cXE0uYqI0Uw:APA91bHg-example-token\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/citizen-login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "citizen-login"]
            }
          }
        },
        {
          "name": "Social Login with FCM Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"social@example.com\",\n  \"password\": \"password123\",\n  \"fcmToken\": \"cXE0uYqI0Uw:APA91bHg-example-token\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/social-login",
